{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mynx Installer",
  "version": "2.2.6",
  "identifier": "com.fanguanghan.mynx.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Mynx 安装向导",
        "width": 580,
        "height": 500,
        "minWidth": 580,
        "minHeight": 500,
        "maxWidth": 580,
        "maxHeight": 500,
        "resizable": false,
        "decorations": false,
        "center": true,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost"
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Mynx 安装程序",
    "longDescription": "安装 Mynx 科研数据工具到本机"
  }
}
