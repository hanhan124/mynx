{
  "name": "mynx",
  "private": true,
  "version": "2.2.1",
  "type": "module",
  "repository": "https://github.com/hanhan124/mynx",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "mac:build": "tauri build --target aarch64-apple-darwin",
    "version": "node scripts/sync-version.cjs",
    "prebuild": "node scripts/sync-version.cjs",
    "installer:payload": "node scripts/sync-installer-payload.cjs",
    "installer:dev": "cd installer && npm run tauri:dev",
    "installer:build": "npm run tauri:build -- --no-bundle && npm run installer:payload && cd installer && npm install && npm run tauri:build && node ../scripts/post-installer-build.cjs",
    "installer:clean": "node scripts/clean-installer-artifacts.cjs",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "release": "node scripts/release.cjs"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.44.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.8.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.2.0"
  }
}
